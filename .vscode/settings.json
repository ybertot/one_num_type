{
  "files.exclude": {
    "**/*.out": true,
    "**/*.nav": true,
    "**/*.aux": true,
    "**/*.vos": true,
    "**/*.vok": true,
    "**/*.glob": true,
    "**/.lia.cache": true,
    "**/*.generated.*": true,
    "**/*.vo": true,
    "**/*.generated": true,
  },
  "makefile.configureOnOpen": false,
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex",
      "command": "pdflatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ],
      "env": {}
    },
  ],
  "latex-workshop.latex.recipes": [
    
    {
      "name": "pdflatex",
      "tools": [
        "pdflatex",
      ]
    }
  ]
}